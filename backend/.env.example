# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=bearb_db

# ─── RPC Priority: LOCAL_NODE_RPC > BERACHAIN_RPC > FALLBACK_RPCS ────────────
# Set LOCAL_NODE_RPC to your local Berachain node for maximum speed (~2ms latency)
# Leave empty to use public RPC
LOCAL_NODE_RPC=
# http://localhost:8545   ← uncomment when local node is running

# Primary public RPC (used when local node is unavailable)
BERACHAIN_RPC=https://rpc.berachain.com

# Comma-separated fallback RPCs (tried in order if primary fails)
FALLBACK_RPCS=https://rpc.berachain.com,https://berachain-v2-testnet.drpc.org

# ─── MEV Protection ───────────────────────────────────────────────────────────
PRIVATE_RPC_URL=
USE_PRIVATE_RPC=false

# ─── Mode ─────────────────────────────────────────────────────────────────────
PRODUCTION_MODE=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ─── Wallet (fill in for trade execution) ─────────────────────────────────────
# WARNING: Never commit this file to git with real keys!
PRIVATE_KEY=
FLASH_ARB_CONTRACT=
